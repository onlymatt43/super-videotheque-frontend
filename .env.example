# super-videotheque-frontend environment template

# Optional external API URL (legacy/optional)
VITE_API_BASE_URL=
VITE_API_URL=https://super-videotheque-api.onrender.com

# Read-only bridge (server-side)
READ_ONLY_URL=https://read-only.vercel.app
READ_ONLY_SERVICE_KEY=
NEXT_PUBLIC_DEST=super-videotheque
WEBHOOK_SECRET_SUPER_VIDEOTHEQUE=

# Payment hub URL (must match backend hub URL)
VITE_PAYMENT_ONLY_URL=https://payment-only-nu.vercel.app

# Product slug used by payment-only validate page
VITE_PRODUCT_SLUG=super-videotheque

# Optional billing flags
VITE_CCBILL_ENABLED=false
